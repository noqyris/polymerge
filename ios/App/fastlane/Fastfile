# Polymerge — App Store automation.
#
# Auth: an App Store Connect API key (no Apple ID login, no 2FA). Put these in
# ios/App/fastlane/.env (gitignored) after creating the key in App Store Connect
# → Users and Access → Integrations → App Store Connect API:
#
#   ASC_KEY_ID=XXXXXXXXXX
#   ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#   ASC_KEY_PATH=./fastlane/AuthKey_XXXXXXXXXX.p8
#
# Lanes:
#   fastlane check     — validate the listing for common rejection reasons
#   fastlane metadata  — push text + screenshots only (no binary, no submit)
#   fastlane release   — build, upload binary + metadata + screenshots, submit

default_platform(:ios)

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: ENV.fetch("ASC_KEY_PATH"),
    duration: 1200,
    in_house: false,
    set_spaceship_token: true, # also applies to spaceship actions like produce
  )
end

platform :ios do
  # Ensures the bundle id is registered (API-allowed) and checks whether the app
  # record exists. Apple does NOT allow creating the app record via the API, so
  # that one step is done once in the App Store Connect UI.
  desc "Register bundle id + check the app record exists"
  lane :create_app do
    require "spaceship"
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV.fetch("ASC_KEY_ID"), issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      filepath: ENV.fetch("ASC_KEY_PATH"),
    )
    bid = "com.noqyris.polymerge"
    unless Spaceship::ConnectAPI::BundleId.all(filter: { identifier: bid }).any? { |b| b.identifier == bid }
      Spaceship::ConnectAPI::BundleId.create(name: "Polymerge", identifier: bid, platform: "IOS")
      UI.success("Registered bundle id #{bid}")
    end
    if (app = Spaceship::ConnectAPI::App.find(bid))
      UI.success("App record ready: #{app.name} (#{bid}) — run `fastlane metadata`")
    else
      UI.important("Bundle id is registered, but the app record must be created once in the UI:")
      UI.message("  App Store Connect → My Apps → + → New App → iOS")
      UI.message("  Bundle ID: #{bid} · Name: Polymerge: Polygon Merge · SKU: polymerge-ios-001 · Language: English (U.S.)")
      UI.message("  Then re-run this lane, followed by `fastlane metadata`.")
    end
  end

  desc "Verify the API key authenticates and list the account's apps"
  lane :auth_test do
    require "spaceship"
    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      filepath: File.absolute_path(ENV.fetch("ASC_KEY_PATH")),
    )
    Spaceship::ConnectAPI.token = token
    apps = Spaceship::ConnectAPI::App.all
    UI.success("Auth OK — #{apps.count} app(s) visible on this account")
    apps.each { |a| UI.message("• #{a.name} — #{a.bundle_id}") }
  end

  desc "Read support/privacy URLs from existing apps to reuse for Polymerge"
  lane :peek_urls do
    require "spaceship"
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV.fetch("ASC_KEY_ID"), issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      filepath: ENV.fetch("ASC_KEY_PATH"),
    )
    ["com.noqyris.exactly67", "com.noqyris.moonsoon"].each do |bid|
      app = Spaceship::ConnectAPI::App.find(bid)
      next UI.message("#{bid}: not found") unless app
      UI.important(bid)
      ver = (app.get_live_app_store_version rescue nil) || (app.get_edit_app_store_version rescue nil)
      (ver&.get_app_store_version_localizations rescue []).each do |l|
        UI.message("  #{l.locale}: support=#{l.support_url} marketing=#{l.marketing_url}")
      end
      info = (app.fetch_live_app_info rescue nil) || (app.fetch_edit_app_info rescue nil)
      (info&.get_app_info_localizations rescue []).each do |l|
        UI.message("  #{l.locale}: privacy=#{l.privacy_policy_url}")
      end
    end
  end

  desc "Show the processing state of recent builds"
  lane :build_status do
    require "spaceship"
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV.fetch("ASC_KEY_ID"), issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      filepath: ENV.fetch("ASC_KEY_PATH"),
    )
    app = Spaceship::ConnectAPI::App.find("com.noqyris.polymerge")
    builds = app.get_builds(includes: "preReleaseVersion")
    if builds.empty?
      UI.important("No builds yet — still processing on Apple's side.")
    else
      builds.first(5).each { |b| UI.message("build #{b.version} — #{b.processing_state}") }
    end
  end

  desc "Read the App Review contact info from an existing app to reuse"
  lane :peek_review do
    require "spaceship"
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV.fetch("ASC_KEY_ID"), issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      filepath: ENV.fetch("ASC_KEY_PATH"),
    )
    ["com.noqyris.moonsoon", "com.noqyris.exactly67"].each do |bid|
      app = Spaceship::ConnectAPI::App.find(bid)
      next unless app
      ver = (app.get_live_app_store_version rescue nil) || (app.get_edit_app_store_version rescue nil)
      d = (ver&.fetch_app_store_review_detail rescue nil) || (ver&.app_store_review_detail rescue nil)
      next unless d
      UI.important(bid)
      UI.message("  phone=#{d.contact_phone} email=#{d.contact_email} name=#{d.contact_first_name} #{d.contact_last_name}")
    end
  end

  desc "Validate listing metadata for common App Review rejection reasons"
  lane :check do
    precheck(api_key: asc_api_key)
  end

  desc "Build + sign + upload the binary (no submit)"
  lane :build_upload do
    api = asc_api_key
    build_app(
      project: "App.xcodeproj",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates DEVELOPMENT_TEAM=YMN45WC2QR",
      export_options: { teamID: "YMN45WC2QR", signingStyle: "automatic" },
      output_directory: "./build",
      clean: true,
    )
    upload_to_app_store(
      api_key: api,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      run_precheck_before_submit: false,
      force: true,
    )
  end

  desc "Upload only the screenshots (no text metadata, no binary, no submit)"
  lane :screenshots do
    deliver(
      api_key: asc_api_key,
      skip_metadata: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      force: true,
    )
  end

  desc "Upload text metadata + review info only (screenshots via the screenshots lane)"
  lane :metadata do
    deliver(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_screenshots: true,
      submit_for_review: false,
      run_precheck_before_submit: false,
      force: true,
    )
  end

  desc "Submit the current version for review (attaches the latest processed build)"
  lane :submit do
    deliver(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: true,
      automatic_release: true,
      run_precheck_before_submit: false,
      submission_information: {
        export_compliance_uses_encryption: false,
        add_id_info_uses_idfa: false,
      },
      force: true,
    )
  end

  desc "Build, upload binary + metadata + screenshots, and submit for review"
  lane :release do
    build_app(
      project: "App.xcodeproj",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates",
      output_directory: "./build",
      clean: true,
    )
    deliver(
      api_key: asc_api_key,
      submit_for_review: true,
      automatic_release: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      run_precheck_before_submit: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        export_compliance_uses_encryption: false,
        add_id_info_uses_idfa: false,
      },
      force: true,
    )
  end
end
