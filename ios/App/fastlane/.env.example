# Copy this file to `.env` (same folder) and fill in your App Store Connect API
# key. The .env file is gitignored — never commit your key.
#
# Create the key once: App Store Connect → Users and Access → Integrations →
# App Store Connect API → "+". Role: App Manager (or Admin). Download the
# AuthKey_XXXXXXXXXX.p8 (you can only download it once) into this folder.

ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_KEY_PATH=./fastlane/AuthKey_XXXXXXXXXX.p8
